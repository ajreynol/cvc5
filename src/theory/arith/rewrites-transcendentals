; trancendentals

(define-rule arith-sine-zero () (sin 0/1) 0/1)
(define-rule arith-sine-pi2 () (sin (* 1/2 real.pi)) 1/1)
(define-rule arith-cosine-elim ((x Real)) (cos x) (sin (- (* 1/2 real.pi) x)))
(define-rule arith-tangent-elim ((x Real)) (tan x) (/ (sin x) (cos x)))
(define-rule arith-secent-elim ((x Real)) (sec x) (/ 1/1 (cos x)))
(define-rule arith-cosecent-elim ((x Real)) (csc x) (/ 1/1 (sin x)))
(define-rule arith-cotangent-elim ((x Real)) (cot x) (/ (cos x) (sin x)))

(define-rule arith-pi-not-int () (is_int real.pi) false)

; Marked :exec to demonstrate the executable rewrite trie (a "direct", i.e.
; no-:list-variable, pattern). The double-angle identity is not applied by the
; hand-written rewriter, so it survives to the last-effort exec pass.
(define-rule arith-sine-double ((x Real)) (sin (* 2 x)) (* 2 (sin x) (cos x)) :exec)

; Marked :exec to demonstrate a *conditional* executable rewrite. The condition
; (here trivially true) is verified by rewriting it to true before the rule is
; applied; in proof mode it yields a TRUST_THEORY_REWRITE premise.
(define-cond-rule arith-sine-quad ((x Real)) (= x x)
  (sin (* 4 x)) (* 2 (sin (* 2 x)) (cos (* 2 x))) :exec)

